{
  "$ref": "#/definitions/GateDecisionSchema",
  "definitions": {
    "GateDecisionSchema": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "runId": {
          "type": "string",
          "format": "uuid"
        },
        "phaseId": {
          "type": "string",
          "format": "uuid"
        },
        "decision": {
          "type": "string",
          "enum": [
            "pass",
            "warn",
            "fail"
          ]
        },
        "criticalCount": {
          "type": "integer",
          "minimum": 0
        },
        "highCount": {
          "type": "integer",
          "minimum": 0
        },
        "mediumCount": {
          "type": "integer",
          "minimum": 0
        },
        "lowCount": {
          "type": "integer",
          "minimum": 0
        },
        "policyApplied": {
          "type": "string"
        },
        "decidedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "runId",
        "decision",
        "criticalCount",
        "highCount",
        "mediumCount",
        "lowCount",
        "policyApplied",
        "decidedAt"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
