{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "apiKey": {
      "type": "string",
      "minLength": 1
    },
    "appKey": {
      "type": "string",
      "minLength": 1
    },
    "site": {
      "default": "datadoghq.com",
      "type": "string",
      "enum": [
        "datadoghq.com",
        "datadoghq.eu"
      ]
    }
  },
  "required": [
    "apiKey",
    "appKey",
    "site"
  ],
  "additionalProperties": false
}
