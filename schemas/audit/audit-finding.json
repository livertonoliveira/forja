{
  "$ref": "#/definitions/AuditFinding",
  "definitions": {
    "AuditFinding": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "1.0"
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[\\w:\\-]+$"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "category": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "filePath": {
          "type": "string"
        },
        "line": {
          "type": "number"
        },
        "endLine": {
          "type": "number"
        },
        "snippet": {
          "type": "string",
          "maxLength": 2048
        },
        "cwe": {
          "type": "string",
          "maxLength": 32
        },
        "remediation": {
          "type": "string",
          "maxLength": 4096
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      },
      "required": [
        "schemaVersion",
        "id",
        "severity",
        "title",
        "category",
        "description"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
