{
  "name": "@forja-hq/cli",
  "version": "0.1.2",
  "description": "Automated development pipeline for Claude Code — from issue to PR with quality gates, parallel agents, and persistent artifacts.",
  "type": "module",
  "license": "BUSL-1.1",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin/",
    "src/",
    "commands/",
    "policies/",
    "apps/ui/.next/standalone/",
    "apps/ui/.next/static/",
    "apps/ui/public/",
    "docker-compose.yml",
    "CLAUDE.forja.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "forja": "bin/forja.js"
  },
  "scripts": {
    "build": "tsx esbuild.config.ts && npm run build:ui",
    "build:ui": "cd apps/ui && npm install --legacy-peer-deps && npm run build && cp -r .next/static .next/standalone/.next/static",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests tests/",
    "test:update-golden": "UPDATE_GOLDEN=1 vitest run --passWithNoTests tests/golden.test.ts",
    "version:bump": "bash scripts/bump-version.sh",
    "check:schemas": "tsx scripts/check-schema-coverage.ts"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "cron-parser": "^5.5.0",
    "drizzle-orm": "^0.30.10",
    "js-yaml": "^4.1.0",
    "nanoid": "^5.1.9",
    "pg": "^8.11.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "drizzle-kit": "^0.21.2",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
