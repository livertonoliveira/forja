{
  "name": "forja-harness-engine",
  "version": "0.1.0",
  "description": "Forja CLI and harness engine",
  "type": "module",
  "bin": {
    "forja": "./bin/forja"
  },
  "scripts": {
    "build": "tsx esbuild.config.ts",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --pool=threads --passWithNoTests tests/",
    "version:bump": "bash scripts/bump-version.sh",
    "check:schemas": "tsx scripts/check-schema-coverage.ts"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "cron-parser": "^5.5.0",
    "drizzle-orm": "^0.30.10",
    "js-yaml": "^4.1.0",
    "nanoid": "^5.1.9",
    "pg": "^8.11.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "drizzle-kit": "^0.21.2",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
